# Royal King Seeds Australia — Environment Variables
# Copy this to .env.local and fill in actual values

# Site
NEXT_PUBLIC_SITE_URL=https://royalkingseeds.au

# WooCommerce (product data source)
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_BASE_URL=https://royalkingseeds.au

# Accept.Blue Payment Gateway
ACCEPT_BLUE_API_KEY=
ACCEPT_BLUE_PIN=
ACCEPT_BLUE_API_URL=https://api.accept.blue/api/v2

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email)
RESEND_API_KEY=

# Anthropic (AI chat)
ANTHROPIC_API_KEY=

# IndexNow (optional)
INDEXNOW_SECRET=

# Search Engine Verification (optional)
NEXT_PUBLIC_BING_VERIFY=
NEXT_PUBLIC_YAHOO_VERIFY=
NEXT_PUBLIC_YANDEX_VERIFY=
